<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">苏超联赛</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="HandleNavigate">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> 首页
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="teams" @onclick="HandleNavigate">
                <span class="bi bi-building-nav-menu" aria-hidden="true"></span> 球队
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="standings" @onclick="HandleNavigate">
                <span class="bi bi-trophy-nav-menu" aria-hidden="true"></span> 积分榜
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="schedule" @onclick="HandleNavigate">
                <span class="bi bi-calendar-nav-menu" aria-hidden="true"></span> 赛程
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="stats" @onclick="HandleNavigate">
                <span class="bi bi-bar-chart-nav-menu" aria-hidden="true"></span> 数据分析
            </NavLink>
        </div>
    </nav>
</div>

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private async Task HandleNavigate()
    {
        if (OnNavigate.HasDelegate)
        {
            await OnNavigate.InvokeAsync();
        }
    }
}
