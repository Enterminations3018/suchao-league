@page "/stats"
@inject LeagueService LeagueService
@using SuchaoLeagueWasm.Models

<PageTitle>苏超联赛 - 数据分析</PageTitle>

<div class="container mt-4">
    <h1 class="display-4 text-center mb-5 fw-bold">📈 赛事数据分析</h1>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header text-white" style="background: linear-gradient(90deg, #eab308 0%, #f97316 100%);">
                    <h2 class="h4 fw-bold mb-0">🥇 射手榜</h2>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>排名</th>
                                    <th>球员</th>
                                    <th>球队</th>
                                    <th>位置</th>
                                    <th>进球</th>
                                    <th>助攻</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (topScorers != null && topScorers.Any())
                                {
                                    @foreach (var scorer in topScorers)
                                    {
                                        var idx = topScorers.IndexOf(scorer);
                                        <tr class="@(idx == 0 ? "table-warning" : "")">
                                            <td>
                                                @if (idx == 0) { <span>🥇</span> }
                                                else if (idx == 1) { <span>🥈</span> }
                                                else if (idx == 2) { <span>🥉</span> }
                                                else { @(idx + 1) }
                                            </td>
                                            <td class="fw-bold">@scorer.Player.Name</td>
                                            <td>
                                                <span class="badge text-white" style="background-color: @scorer.Team.ColorPrimary;">@scorer.Team.ShortName</span>
                                            </td>
                                            <td>@scorer.Player.Position</td>
                                            <td class="fw-bold text-success">@scorer.Goals</td>
                                            <td class="fw-bold text-primary">@scorer.Assists</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header text-white" style="background: linear-gradient(90deg, #ef4444 0%, #ec4899 100%);">
                    <h2 class="h4 fw-bold mb-0">📊 球队攻防统计</h2>
                </div>
                <div class="card-body">
                    @if (teamStats != null && teamStats.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var stat in teamStats.OrderByDescending(s => s.GoalsScored).Take(5))
                            {
                                <div class="border rounded p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center">
                                            <div class="d-flex align-items-center justify-content-center text-white fw-bold me-2 rounded-circle"
                                                 style="width: 32px; height: 32px; background-color: @stat.Team.ColorPrimary; font-size: 0.875rem;">
                                                @stat.Team.ShortName[0]
                                            </div>
                                            <span class="fw-bold">@stat.Team.Name</span>
                                        </div>
                                        <div class="small">
                                            <span class="fw-bold text-success">@stat.GoalsScored</span>
                                            <span class="text-muted"> / </span>
                                            <span class="fw-bold text-danger">@stat.GoalsConceded</span>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-6">
                                            <div class="small text-muted">控球率</div>
                                            <div class="fw-bold">@stat.PossessionRate%</div>
                                        </div>
                                        <div class="col-6">
                                            <div class="small text-muted">零封场次</div>
                                            <div class="fw-bold">@stat.CleanSheets</div>
                                        </div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-6">
                                            <div class="small text-muted">射正次数</div>
                                            <div class="fw-bold">@stat.ShotsOnTarget</div>
                                        </div>
                                        <div class="col-6">
                                            <div class="small text-muted">黄牌/红牌</div>
                                            <div class="fw-bold">@stat.YellowCards / @stat.RedCards</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header text-white" style="background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);">
            <h2 class="h4 fw-bold mb-0">🏆 赛事数据总览</h2>
        </div>
        <div class="card-body">
            <div class="row text-center g-3">
                <div class="col-6 col-md-4">
                    <div class="card text-white p-4" style="background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);">
                        <div class="fw-bold" style="font-size: 2.5rem;">@totalGoals</div>
                        <div class="small mt-1">总进球数</div>
                        <div class="small mt-1" style="opacity: 0.8;">场均 @avgGoalsPerMatch.ToString("F1") 球</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card text-white p-4" style="background: linear-gradient(135deg, #60a5fa 0%, #2563eb 100%);">
                        <div class="fw-bold" style="font-size: 2.5rem;">@cleanSheetsCount</div>
                        <div class="small mt-1">零封场次</div>
                        <div class="small mt-1" style="opacity: 0.8;">占比 @cleanSheetRate.ToString("F1")%</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card text-white p-4" style="background: linear-gradient(135deg, #c084fc 0%, #9333ea 100%);">
                        <div class="fw-bold" style="font-size: 2.5rem;">@avgPossession.ToString("F1")%</div>
                        <div class="small mt-1">平均控球率</div>
                        <div class="small mt-1" style="opacity: 0.8;">攻守兼备</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card text-white p-4" style="background: linear-gradient(135deg, #facc15 0%, #f97316 100%);">
                        <div class="fw-bold" style="font-size: 2.5rem;">@yellowCardsTotal</div>
                        <div class="small mt-1">黄牌总数</div>
                        <div class="small mt-1" style="opacity: 0.8;">纪律统计</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card text-white p-4" style="background: linear-gradient(135deg, #f87171 0%, #dc2626 100%);">
                        <div class="fw-bold" style="font-size: 2.5rem;">@redCardsTotal</div>
                        <div class="small mt-1">红牌总数</div>
                        <div class="small mt-1" style="opacity: 0.8;">严重犯规</div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="card text-white p-4" style="background: linear-gradient(135deg, #5eead4 0%, #0d9488 100%);">
                        <div class="fw-bold" style="font-size: 2.5rem;">@completedMatchesCount</div>
                        <div class="small mt-1">已完赛场次</div>
                        <div class="small mt-1" style="opacity: 0.8;">常规赛进度</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<TopScorer> topScorers = [];
    private List<TeamStats> teamStats = [];
    private List<Match> completedMatches = [];

    private int totalGoals => teamStats != null && teamStats.Any() ? teamStats.Sum(s => s.GoalsScored) : 0;
    private int completedMatchesCount => completedMatches != null ? completedMatches.Count : 0;
    private double avgGoalsPerMatch => completedMatchesCount > 0 ? (double)totalGoals / completedMatchesCount : 0;
    private int cleanSheetsCount => teamStats != null && teamStats.Any() ? teamStats.Sum(s => s.CleanSheets) : 0;
    private double cleanSheetRate => completedMatchesCount > 0 ? (double)cleanSheetsCount / (completedMatchesCount * 2) * 100 : 0;
    private double avgPossession => teamStats != null && teamStats.Any() ? teamStats.Average(s => s.PossessionRate) : 0;
    private int yellowCardsTotal => teamStats != null && teamStats.Any() ? teamStats.Sum(s => s.YellowCards) : 0;
    private int redCardsTotal => teamStats != null && teamStats.Any() ? teamStats.Sum(s => s.RedCards) : 0;

    protected override void OnInitialized()
    {
        try
        {
            topScorers = LeagueService.GetTopScorers() ?? [];
            teamStats = LeagueService.GetTeamTeamStats() ?? [];
            completedMatches = LeagueService.GetCompletedMatches() ?? [];
        }
        catch
        {
            topScorers = [];
            teamStats = [];
            completedMatches = [];
        }
    }
}