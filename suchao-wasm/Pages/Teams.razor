@page "/teams"
@inject LeagueService LeagueService

<PageTitle>苏超联赛 - 球队</PageTitle>

<div class="container mt-4">
    <h1 class="display-4 text-center mb-5 fw-bold">🏟️ 13支球队巡礼</h1>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @if (teams != null && teams.Any())
        {
            @foreach (var team in teams)
            {
                <div class="col d-flex">
                    <div class="card w-100 h-100">
                        <div class="card-header py-3 text-center" style="background: linear-gradient(135deg, @team.ColorPrimary 0%, @team.ColorSecondary 100%);">
                            <h3 class="h5 fw-bold text-white mb-0">@team.Name</h3>
                            <p class="small text-white mb-0" style="opacity: 0.8;">主教练：@team.Coach</p>
                        </div>
                        <div class="card-body">
                            <p class="small text-muted mb-2">主场：@team.HomeStadium (@team.Capacity.ToString("N0")人)</p>

                            <p class="small mb-3">@team.Description</p>

                            <div class="mb-3">
                                <div class="small fw-bold mb-1 text-secondary">战术风格</div>
                                <div class="small">@team.Tactics</div>
                                <div class="small text-muted mt-1">阵型：@team.Formation</div>
                            </div>

                            <div>
                                <div class="small fw-bold mb-2 text-secondary">核心球员</div>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var player in team.KeyPlayers)
                                    {
                                        <div class="d-flex align-items-center small">
                                            <span class="d-inline-flex align-items-center justify-content-center bg-light rounded me-2" style="width: 24px; height: 24px; font-size: 0.75rem;">@player.JerseyNumber</span>
                                            <span class="fw-medium">@player.Name</span>
                                            <span class="text-muted ms-auto small">@player.Position</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">暂无球队数据</div>
        }
    </div>
</div>

@code {
    private List<Team> teams = [];

    protected override void OnInitialized()
    {
        try
        {
            teams = LeagueService.GetAllTeams() ?? [];
        }
        catch
        {
            teams = [];
        }
    }
}