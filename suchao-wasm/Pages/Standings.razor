@page "/standings"
@inject LeagueService LeagueService
@using SuchaoLeagueWasm.Models

<PageTitle>苏超联赛 - 积分榜</PageTitle>

<div class="container mt-4">
    <h1 class="display-4 text-center mb-5 fw-bold">📊 2026苏超积分榜</h1>

    <div class="d-block d-md-none mb-4">
        @if (standings != null && standings.Any())
        {
            @foreach (var standing in standings)
            {
                <div class="card mb-2 @(standing.Rank <= 3 ? "border-warning" : "")">
                    <div class="card-body p-2">
                        <div class="d-flex align-items-center gap-2">
                            <span style="font-size: 1.5rem;">@(standing.Rank == 1 ? "🥇" : standing.Rank == 2 ? "🥈" : standing.Rank == 3 ? "🥉" : $"{standing.Rank}")</span>
                            <div class="d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0 rounded-circle"
                                 style="width: 32px; height: 32px; background-color: @standing.Team.ColorPrimary; font-size: 0.875rem;">
                                @standing.Team.ShortName[0]
                            </div>
                            <div class="flex-grow-1" style="min-width: 0;">
                                <div class="fw-bold text-truncate" style="color: @standing.Team.ColorPrimary;">@standing.Team.Name</div>
                                <div class="small text-muted">@standing.Team.City</div>
                            </div>
                            <div class="text-end flex-shrink-0">
                                <div class="fw-bold @(standing.Rank <= 3 ? "text-warning" : "text-primary")" style="font-size: 1.5rem;">@standing.Points</div>
                                <div class="small text-muted">分</div>
                            </div>
                        </div>
                        <div class="row text-center mt-2 g-1 small">
                            <div class="col-4"><span class="text-muted">胜</span> <span class="text-success fw-bold">@standing.Won</span></div>
                            <div class="col-4"><span class="text-muted">平</span> <span class="text-warning fw-bold">@standing.Drawn</span></div>
                            <div class="col-4"><span class="text-muted">负</span> <span class="text-danger fw-bold">@standing.Lost</span></div>
                        </div>
                        <div class="row text-center g-1 small mt-1">
                            <div class="col-6"><span class="text-muted">进</span> @standing.GoalsFor - <span class="text-muted">失</span> @standing.GoalsAgainst</div>
                            <div class="col-6"><span class="text-muted">净</span> <span class="@((standing.GoalDifference > 0) ? "text-success" : (standing.GoalDifference < 0) ? "text-danger" : "")">@standing.GoalDifference</span></div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="card d-none d-md-block">
        <div class="card-header text-white" style="background: linear-gradient(90deg, #2563eb 0%, #9333ea 100%);">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h2 class="h4 fw-bold mb-0">常规赛积分榜</h2>
                </div>
                <div class="col-md-6 text-end">
                    <span class="small">更新时间：@DateTime.Now.ToShortDateString()</span>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th scope="col" class="text-center">排名</th>
                            <th scope="col">球队</th>
                            <th scope="col" class="text-center">赛</th>
                            <th scope="col" class="text-center">胜</th>
                            <th scope="col" class="text-center">平</th>
                            <th scope="col" class="text-center">负</th>
                            <th scope="col" class="text-center d-none d-lg-table-cell">进</th>
                            <th scope="col" class="text-center d-none d-lg-table-cell">失</th>
                            <th scope="col" class="text-center d-none d-md-table-cell">净</th>
                            <th scope="col" class="text-center">积分</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (standings != null && standings.Any())
                        {
                            @foreach (var standing in standings)
                            {
                                <tr class="@(standing.Rank == 1 ? "table-warning" : "")">
                                    <td class="text-center align-middle">
                                        @(standing.Rank == 1 ? "🥇" : standing.Rank == 2 ? "🥈" : standing.Rank == 3 ? "🥉" : standing.Rank.ToString())
                                    </td>
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="d-flex align-items-center justify-content-center text-white fw-bold me-3 flex-shrink-0 rounded-circle"
                                                 style="width: 32px; height: 32px; background-color: @standing.Team.ColorPrimary; font-size: 0.875rem;">
                                                @standing.Team.ShortName[0]
                                            </div>
                                            <div>
                                                <div class="fw-bold" style="color: @standing.Team.ColorPrimary;">@standing.Team.Name</div>
                                                <div class="small text-muted d-none d-xl-block">@standing.Team.City</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">@standing.Played</td>
                                    <td class="text-center align-middle text-success fw-bold">@standing.Won</td>
                                    <td class="text-center align-middle text-warning fw-bold">@standing.Drawn</td>
                                    <td class="text-center align-middle text-danger fw-bold">@standing.Lost</td>
                                    <td class="text-center align-middle d-none d-lg-table-cell">@standing.GoalsFor</td>
                                    <td class="text-center align-middle d-none d-lg-table-cell">@standing.GoalsAgainst</td>
                                    <td class="text-center align-middle fw-bold d-none d-md-table-cell @(standing.GoalDifference > 0 ? "text-success" : standing.GoalDifference < 0 ? "text-danger" : "")">
                                        @(standing.GoalDifference > 0 ? $"+{standing.GoalDifference}" : standing.GoalDifference.ToString())
                                    </td>
                                    <td class="text-center align-middle fw-bold fs-5 @(standing.Rank <= 3 ? "text-warning" : "")">@standing.Points</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-5 g-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header text-white" style="background: linear-gradient(90deg, #22c55e 0%, #14b8a6 100%);">
                    <h3 class="h5 fw-bold mb-0">🔥 进攻火力榜</h3>
                </div>
                <div class="card-body">
                    @if (teamStats != null && teamStats.Any())
                    {
                        var maxGoals = teamStats.Max(s => s.GoalsScored);
                        <div class="d-flex flex-column gap-2">
                            @foreach (var stat in teamStats.OrderByDescending(s => s.GoalsScored).Take(5))
                            {
                                <div class="d-flex align-items-center">
                                    <div class="d-flex align-items-center justify-content-center text-white fw-bold me-2 flex-shrink-0 rounded-circle"
                                         style="width: 24px; height: 24px; background-color: @stat.Team.ColorPrimary; font-size: 0.75rem;">
                                        @stat.Team.ShortName[0]
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between small">
                                            <span class="fw-medium">@stat.Team.ShortName</span>
                                            <span class="fw-bold text-success">@stat.GoalsScored</span>
                                        </div>
                                        <div class="progress mt-1" style="height: 4px;">
                                            <div class="progress-bar" role="progressbar"
                                                 style="width: @(stat.GoalsScored * 100.0 / maxGoals)%; background-color: @stat.Team.ColorPrimary;"></div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header text-white" style="background: linear-gradient(90deg, #3b82f6 0%, #6366f1 100%);">
                    <h3 class="h5 fw-bold mb-0">🛡️ 防守稳固榜</h3>
                </div>
                <div class="card-body">
                    @if (teamStats != null && teamStats.Any())
                    {
                        var maxConceded = teamStats.Max(s => s.GoalsConceded);
                        <div class="d-flex flex-column gap-2">
                            @foreach (var stat in teamStats.OrderBy(s => s.GoalsConceded).Take(5))
                            {
                                var width = (maxConceded - stat.GoalsConceded + 1) * 100.0 / maxConceded;
                                <div class="d-flex align-items-center">
                                    <div class="d-flex align-items-center justify-content-center text-white fw-bold me-2 flex-shrink-0 rounded-circle"
                                         style="width: 24px; height: 24px; background-color: @stat.Team.ColorPrimary; font-size: 0.75rem;">
                                        @stat.Team.ShortName[0]
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between small">
                                            <span class="fw-medium">@stat.Team.ShortName</span>
                                            <span class="fw-bold text-primary">@stat.GoalsConceded</span>
                                        </div>
                                        <div class="progress mt-1" style="height: 4px;">
                                            <div class="progress-bar" role="progressbar"
                                                 style="width: @(width)%; background-color: @stat.Team.ColorPrimary;"></div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Standing> standings = [];
    private List<TeamStats> teamStats = [];

    protected override void OnInitialized()
    {
        try
        {
            standings = LeagueService.GetStandings() ?? [];
            teamStats = LeagueService.GetTeamTeamStats() ?? [];
        }
        catch
        {
            standings = [];
            teamStats = [];
        }
    }
}